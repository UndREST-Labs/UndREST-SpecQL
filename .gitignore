# Generated SARIF and query results
# Owned by: `run-queries.sh`, local CodeQL CLI runs, and `.github/workflows/speql-security-scan.yml`
results/
*.sarif

# CodeQL temporary files and downloaded local tool copies
# Owned by: local CodeQL CLI setup and query execution
.codeql/
*.qls
codeql-javascript/
codeql-shared/
codeql/

# Local Python cache and build artefacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local virtual environments
.venv/
venv/
env/
ENV/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Cloned upstream API spec corpus
# Owned by: `refresh_database.py`, `refresh-database.sh`, and export/scan workflows
azure-rest-api-specs/

# Generated CodeQL databases and build logs
# Owned by: `refresh_database.py`, `refresh-database.sh`, and `.github/workflows/speql-security-scan.yml`
database/

# Generated API inventory exports, shards, and packaged release inputs
# Owned by: `scripts/export/export_api_inventory.py`,
# `.github/workflows/daily-api-index-export.yml`, and
# `.github/workflows/daily-api-index-export-sharded.yml`
inventory/*.json
inventory/*.min.json
inventory/shards/
inventory/*.zip

# APISpy portal sweep output files
apispy/scripts/apispy-*.csv
apispy/scripts/apispy-*.webm

# Results directory
results/
*.sarif

# CodeQL temporary files
.codeql/
*.qls

# CodeQL libraries (downloaded/extracted)
codeql-javascript/
codeql-shared/
codeql/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Azure REST API specs clone (managed by refresh scripts)
azure-rest-api-specs/

# Database directory (created by refresh scripts, not tracked in git)
# Empty directories can't be committed to Git
database/

# API inventory export output (generated by scripts/export/)
inventory/*.json
inventory/*.min.json

# APISpy portal sweep output files
apispy/scripts/apispy-*.csv
apispy/scripts/apispy-*.webm

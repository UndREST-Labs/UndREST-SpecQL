# VHS tape for demonstrating Python security analysis
# This demo shows how to run the Python analyzer on the database

Output demos/03-python-analyzer.gif

Set Shell bash
Set FontSize 16
Set Width 1000
Set Height 720
Set Theme "TokyoNight"
Set TypingSpeed 80ms
Set WindowBar ColorfulRight

Hide
Type "cd /home/runner/work/SpecRecon/SpecRecon"
Enter 1
Show

Type "python3 analyze.py --source azure-rest-api-specs/specification/logic"
Enter 1
Sleep 10s

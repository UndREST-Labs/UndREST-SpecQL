# VHS tape for demonstrating the interactive CLI menu
# This demo shows how to navigate and use the SpeQL CLI

Output demos/05-cli-menu.gif

Set Shell bash
Set FontSize 16
Set Width 1000
Set Height 720
Set Theme "TokyoNight"
Set TypingSpeed 80ms
Set WindowBar ColorfulRight

Hide
Type "cd /home/runner/work/SpecRecon/SpecRecon"
Enter 1
Show

Type "python3 SpeQL.py"
Enter 1
Sleep 3s

Type "1"
Sleep 100ms
Enter 1
Sleep 4s

Type "0"
Sleep 100ms
Enter 1
Sleep 2s

Type "2"
Sleep 100ms
Enter 1
Sleep 4s

Type "0"
Sleep 100ms
Enter 1
Sleep 2s

Type "6"
Sleep 100ms
Enter 1
Sleep 4s

Type "0"
Sleep 100ms
Enter 1
Sleep 2s

Type "0"
Sleep 100ms
Enter 1
Sleep 1s
